*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Binary Files
*/Binaries/*

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
*/Saved/*

# Compiled source files for the engine to use
*/Intermediate/*
*/Intermediate/*

# Cache files for the editor to use
*/DerivedDataCache/*
