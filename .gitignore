# DL Nvidia libs
!*/Binaries/ThirdParty
!DLSS/**/*.lib
!DLSSMoviePipelineSupport/**/*.lib
!NIS/**/*.lib
!Streamline/**/*.lib


# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a

# Executables
*.exe
*.out
*.app
*.ipa

